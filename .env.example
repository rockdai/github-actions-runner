# GitHub repository (owner/repo)
GITHUB_REPO=rockdai/kongkong

# GitHub Personal Access Token (fine-grained, repo scope with Administration: Read & Write)
# Create at: https://github.com/settings/tokens?type=beta
ACCESS_TOKEN=github_pat_xxxxx

# Runner display name (optional, default: runner-<random>)
# RUNNER_NAME=my-runner
